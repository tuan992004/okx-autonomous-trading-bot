{
    "name": "okx-bot",
    "private": true,
    "type": "module",
    "version": "1.0.0",
    "description": "Autonomous OKX crypto trading bot with multi-agent architecture",
    "scripts": {
        "build": "tsc -b packages/shared packages/state packages/scanner packages/validator packages/decision packages/journal packages/orchestrator",
        "dev": "tsx packages/orchestrator/src/index.ts",
        "shadow": "cross-env LIVE_TRADING=false tsx packages/orchestrator/src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "cross-env": "^7.0.3",
        "typescript": "^5.5.0",
        "tsx": "^4.19.0",
        "vitest": "^2.1.0"
    },
    "engines": {
        "node": ">=18"
    },
    "packageManager": "pnpm@9.15.0"
}