# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Trading Mode ===
# Set to "true" ONLY for live trading. Default is shadow/simulation mode.
LIVE_TRADING=false

# === Environment ===
NODE_ENV=development
LOG_LEVEL=info

# === OKX Profile ===
# Which OKX profile to use from ~/.okx/config.toml
# Use "demo" for paper trading, "live" for real money
OKX_PROFILE=demo
